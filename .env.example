# ─────────────────────────────────────────────────────────────
# Buena Onda — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# From: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Site ─────────────────────────────────────────────────────
# ── NestJS API ──────────────────────────────────────────
# Backend base URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

NEXT_PUBLIC_SITE_URL=https://buenaonda.com

# ── Admin ────────────────────────────────────────────────────
# Password for /admin access gate. If unset, /admin is open (dev mode).
ADMIN_PASSWORD=change-me-in-production

# ── Anthropic (Claude AI — used by sync scripts) ──────────────
# From: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email (Resend) ────────────────────────────────────────────
# From: https://resend.com → API Keys
# Required only if you want contact form emails to be delivered.
RESEND_API_KEY=re_your_api_key_here

# The inbox that receives contact form submissions
CONTACT_EMAIL=hello@buenaonda.com
